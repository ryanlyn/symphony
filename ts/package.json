{
  "name": "@symphony/ts-port",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript port of Symphony orchestration contracts.",
  "bin": {
    "symphony-ts": "./dist/src/bin/symphony-ts.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "CHANGELOG.md",
    "LIVE_E2E_MATRIX.md",
    "WORKFLOW.md",
    "WORKFLOW_FULL_ACCESS.md",
    "WORKFLOW_ENSEMBLE.md",
    "WORKFLOW_ALPHA_EVOLVE.md"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "dev": "tsx src/bin/symphony-ts.ts",
    "start": "node dist/src/bin/symphony-ts.js",
    "start:once": "node dist/src/bin/symphony-ts.js --once",
    "runs": "node dist/src/bin/symphony-ts.js runs",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"test/**/*.ts\" \"README.md\" \"CHANGELOG.md\" \"LIVE_E2E_MATRIX.md\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"test/**/*.ts\" \"README.md\" \"CHANGELOG.md\" \"LIVE_E2E_MATRIX.md\" \"*.json\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/src/bin/symphony-ts.js', 0o755)\"",
    "test": "node --test --test-concurrency=1 --import tsx test/*.test.ts",
    "test:live:codex": "SYMPHONY_TS_RUN_REAL_CODEX_E2E=1 node --test --import tsx test/live-codex.test.ts",
    "test:live:codex-resume": "SYMPHONY_TS_RUN_REAL_CODEX_RESUME_E2E=1 node --test --import tsx test/live-codex-resume.test.ts",
    "test:live:linear-codex": "SYMPHONY_TS_RUN_LINEAR_CODEX_E2E=1 node --test --import tsx test/live-linear-codex.test.ts",
    "test:live:claude": "SYMPHONY_TS_RUN_REAL_CLAUDE_E2E=1 node --test --import tsx test/live-claude.test.ts",
    "test:live:ssh": "SYMPHONY_TS_RUN_LIVE_SSH_E2E=1 node --test --import tsx test/live-ssh.test.ts",
    "test:live": "npm run test:live:codex && npm run test:live:codex-resume && npm run test:live:linear-codex && npm run test:live:claude",
    "test:parity": "node --test --test-concurrency=1 --import tsx test/*.test.ts",
    "test:parity:live": "npm run test:live",
    "proof:parity": "cd .. && bash scripts/parity/run_full_parity.sh"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@hono/node-server": "^1.19.14",
    "acpx": "^0.7.0",
    "execa": "^9.6.1",
    "hono": "^4.12.18",
    "ink": "^7.0.1",
    "liquidjs": "^10.21.1",
    "pino": "^9.14.0",
    "pino-roll": "^3.1.0",
    "react": "^19.2.5",
    "ts-pattern": "^5.9.0",
    "vscode-jsonrpc": "^8.2.1",
    "yaml": "^2.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "eslint": "^10.3.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2"
  }
}
