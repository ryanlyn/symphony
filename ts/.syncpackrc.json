{
  "source": ["package.json", "packages/*/package.json", "apps/*/package.json"],
  "versionGroups": [
    {
      "label": "Workspace packages use workspace:* protocol",
      "dependencies": ["@lorenz/**"],
      "dependencyTypes": ["!local"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "Vendored ACP bridges use workspace:* protocol",
      "dependencies": ["@agentclientprotocol/claude-agent-acp", "@agentclientprotocol/codex-acp"],
      "dependencyTypes": ["!local"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "All deps shared across packages must use catalog:",
      "dependencies": ["**"],
      "dependencyTypes": ["prod", "dev", "peer"],
      "pinVersion": "catalog:"
    }
  ]
}
