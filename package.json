{
  "name": "lorenz",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "Lorenz is a control plane for dispatching and structuring order across dynamic agent systems.",
  "scripts": {
    "dev": "pnpm build && pnpm start",
    "start": "pnpm exec node apps/cli/dist/bin/cli.js",
    "start:once": "pnpm exec node apps/cli/dist/bin/cli.js --once",
    "runs": "pnpm exec node apps/cli/dist/bin/cli.js runs",
    "lint": "eslint --cache --cache-strategy content \"packages/**/*.{ts,tsx}\" \"extensions/**/*.{ts,tsx}\" \"apps/**/*.{ts,tsx}\" \"scripts/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint --cache --cache-strategy content --fix \"packages/**/*.{ts,tsx}\" \"extensions/**/*.{ts,tsx}\" \"apps/**/*.{ts,tsx}\" \"scripts/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --cache --write \"packages/**/*.{ts,tsx}\" \"extensions/**/*.{ts,tsx}\" \"apps/**/*.{ts,tsx}\" \"scripts/**/*.{ts,json}\" \"test/**/*.ts\" \"README.md\" \"CONTRIBUTING.md\" \"*.json\" \"*.yaml\"",
    "format:check": "prettier --cache --check \"packages/**/*.{ts,tsx}\" \"extensions/**/*.{ts,tsx}\" \"apps/**/*.{ts,tsx}\" \"scripts/**/*.{ts,json}\" \"test/**/*.ts\" \"README.md\" \"CONTRIBUTING.md\" \"*.json\" \"*.yaml\"",
    "typecheck": "tsc --build",
    "bundle:bridges": "pnpm --filter @agentclientprotocol/claude-agent-acp bundle",
    "build": "pnpm bundle:bridges && pnpm dashboard:build && tsc --build && chmod +x apps/cli/dist/bin/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live:codex": "LORENZ_TS_RUN_REAL_CODEX_E2E=1 vitest run test/live-codex.test.ts",
    "test:live:linear-codex": "LORENZ_TS_RUN_LINEAR_CODEX_E2E=1 vitest run test/live-linear-codex.test.ts",
    "test:live:claude": "LORENZ_TS_RUN_REAL_CLAUDE_E2E=1 vitest run test/live-claude.test.ts",
    "test:live:ssh": "LORENZ_TS_RUN_LIVE_SSH_E2E=1 vitest run test/live-ssh.test.ts",
    "test:live:linear-sandbox": "LORENZ_TS_RUN_LINEAR_SANDBOX=1 vitest run test/linear-sandbox.test.ts",
    "test:live": "pnpm test:live:codex && pnpm test:live:linear-codex && pnpm test:live:claude",
    "tsconfig:refs": "tsx scripts/sync-tsconfig-refs.ts --write",
    "tsconfig:refs:check": "tsx scripts/sync-tsconfig-refs.ts --check",
    "dashboard": "pnpm start -- --port 4040 --no-tui --once --dry-run",
    "dashboard:ui": "pnpm --filter @lorenz/dashboard dev",
    "dashboard:build": "pnpm --filter @lorenz/dashboard build",
    "traceviz": "pnpm --filter @lorenz/traceviz traceviz",
    "release:bump-version": "tsx scripts/bump-release-version.ts",
    "release:stage": "tsx scripts/stage-release.ts",
    "release:publish": "pnpm build && tsx scripts/publish-release.ts",
    "lint:versions": "syncpack lint",
    "agent-settings:check": "tsx scripts/check-agent-settings-policy.ts",
    "architecture:check": "depcruise --config .dependency-cruiser.cjs packages/*/src extensions/*/src apps/*/src",
    "architecture:graph": "depcruise --config .dependency-cruiser.cjs --output-type mermaid packages/*/src extensions/*/src apps/*/src"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "catalog:",
    "@agentclientprotocol/claude-agent-acp": "workspace:*",
    "@agentclientprotocol/codex-acp": "workspace:*",
    "@eslint/js": "catalog:",
    "@lorenz/acp": "workspace:*",
    "@lorenz/agent-runner": "workspace:*",
    "@lorenz/agent-sdk": "workspace:*",
    "@lorenz/cli": "workspace:*",
    "@lorenz/config": "workspace:*",
    "@lorenz/dispatch": "workspace:*",
    "@lorenz/domain": "workspace:*",
    "@lorenz/humanize": "workspace:*",
    "@lorenz/issue": "workspace:*",
    "@lorenz/jira-tracker": "workspace:*",
    "@lorenz/linear-tracker": "workspace:*",
    "@lorenz/local-tracker": "workspace:*",
    "@lorenz/log-file": "workspace:*",
    "@lorenz/mcp": "workspace:*",
    "@lorenz/memory-tracker": "workspace:*",
    "@lorenz/orchestrator": "workspace:*",
    "@lorenz/policies": "workspace:*",
    "@lorenz/projections": "workspace:*",
    "@lorenz/retry-scheduler": "workspace:*",
    "@lorenz/runtime": "workspace:*",
    "@lorenz/runtime-events": "workspace:*",
    "@lorenz/server": "workspace:*",
    "@lorenz/ssh": "workspace:*",
    "@lorenz/test-utils": "workspace:*",
    "@lorenz/tool-sdk": "workspace:*",
    "@lorenz/traceviz-emitter": "workspace:*",
    "@lorenz/tracker-sdk": "workspace:*",
    "@lorenz/tui": "workspace:*",
    "@lorenz/worker-host-pool": "workspace:*",
    "@lorenz/workflow": "workspace:*",
    "@lorenz/workspace": "workspace:*",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "dependency-cruiser": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "fast-check": "catalog:",
    "ink-testing-library": "catalog:",
    "jsdom": "catalog:",
    "knip": "catalog:",
    "msw": "catalog:",
    "playwright": "catalog:",
    "prettier": "catalog:",
    "syncpack": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  }
}
